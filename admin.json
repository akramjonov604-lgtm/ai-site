import { Router, type IRouter } from "express";
import crypto from "node:crypto";

const router: IRouter = Router();

interface StoredPreview {
  html: string;
  createdAt: number;
}

const previews = new Map<string, StoredPreview>();
const TTL_MS = 1000 * 60 * 60 * 6;
const MAX_ENTRIES = 200;
const MAX_HTML_BYTES = 5 * 1024 * 1024;

function cleanup() {
  const now = Date.now();
  for (const [id, p] of previews) {
    if (now - p.createdAt > TTL_MS) previews.delete(id);
  }
  if (previews.size > MAX_ENTRIES) {
    const entries = [...previews.entries()].sort(
      (a, b) => a[1].createdAt - b[1].createdAt,
    );
    const toRemove = entries.slice(0, previews.size - MAX_ENTRIES);
    for (const [id] of toRemove) previews.delete(id);
  }
}

function serveHtml(id: string, res: import("express").Response) {
  const entry = previews.get(id);
  if (!entry) {
    res
      .status(404)
      .type("html")
      .send(
        `<!doctype html><meta charset="utf-8"><title>Topilmadi · Base55</title>` +
          `<body style="background:#0b0b12;color:#e4e4e7;font-family:system-ui;display:grid;place-items:center;height:100vh;margin:0">` +
          `<div style="text-align:center"><h1 style="color:#a78bfa">404 — Loyiha topilmadi</h1>` +
          `<p>Bu Base55 havolasi eskirgan yoki o'chirib yuborilgan.</p></div></body>`,
      );
    return;
  }
  res.setHeader("Content-Security-Policy", "frame-ancestors *");
  res.type("html").send(entry.html);
}

router.post("/preview", (req, res) => {
  const { html } = req.body ?? {};
  if (typeof html !== "string" || !html.trim()) {
    return res.status(400).json({ error: "html maydoni majburiy" });
  }
  if (Buffer.byteLength(html, "utf8") > MAX_HTML_BYTES) {
    return res.status(413).json({ error: "Loyiha hajmi juda katta" });
  }
  cleanup();
  const id = crypto.randomBytes(9).toString("base64url");
  previews.set(id, { html, createdAt: Date.now() });
  return res.json({ id, url: `/p/${id}` });
});

router.get("/preview/:id", (req, res) => {
  serveHtml(req.params.id, res);
});

export const publicPreviewRouter: IRouter = Router();
publicPreviewRouter.get("/p/:id", (req, res) => {
  serveHtml(req.params.id, res);
});

export default router;
